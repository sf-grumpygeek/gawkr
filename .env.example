# ---- Database ----
POSTGRES_USER=gawkr
POSTGRES_PASSWORD=change-me-alphanumeric
POSTGRES_DB=gawkr

# ---- Web UI ----
WEB_PORT=8080

# ---- UniFi Protect (LOCAL access user, NOT a Ubiquiti SSO/cloud login) ----
UFP_ADDRESS=10.x.x.x
UFP_PORT=443
UFP_USERNAME=gawkr
UFP_PASSWORD=change-me
UFP_SSL_VERIFY=false
UFP_API_KEY=change-me

# ---- Vision model (your llama.cpp / Ollama OpenAI-compatible endpoint) ----
VISION_URL=http://10.x.x.x:8081/v1/chat/completions
VISION_MODEL=qwen2.5-vl
VISION_API_KEY=
VISION_TIMEOUT=60
# Optional site-specific context injected into the describe prompt (background
# only, e.g. "rural property; farm trucks are normal, flag coyotes"). Also
# editable live via the web UI/API without a restart. Blank = off.
DESCRIBE_CONTEXT=

# ---- Whisper transcription (optional; blank = off) ----
# Point at a whisper.cpp / faster-whisper server; scope to mic'd cameras.
WHISPER_URL=
WHISPER_TIMEOUT=120
TRANSCRIBE_CAMERAS=

# ---- Gotify alerts (blank URL+TOKEN = off) ----
GOTIFY_URL=
GOTIFY_TOKEN=
WEB_BASE_URL=http://<host>:8080
ALERT_ON_WEAPON=true
ALERT_THREAT_LEVEL=medium
ALERT_KEYWORDS=
ALERT_CAMERAS=
ALERT_COOLDOWN=120

# ---- Behaviour ----
IDENTIFY_VEHICLES=true
SMART_TYPES=person,vehicle,animal,licensePlate,package,face
EMBED_MODEL=BAAI/bge-small-en-v1.5

# ---- Auth (built-in single app password; see README) ----
# Recommended: authenticate at a reverse proxy instead and leave both of these
# blank -- see README for forward-auth examples. If you don't run a proxy, set
# APP_PASSWORD here for the built-in login page. Blank = auth disabled (loud
# startup warning). Never commit a real value.
APP_PASSWORD=
# Required if APP_PASSWORD is set; refuses to start otherwise. Long random
# string used to sign session cookies -- generate with: openssl rand -hex 32
# Rotating APP_PASSWORD (redeploy with a new value) invalidates all sessions.
SESSION_SECRET=
