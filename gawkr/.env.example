# ---- Database ----
POSTGRES_USER=gawkr
POSTGRES_PASSWORD=change-me-alphanumeric
POSTGRES_DB=gawkr

# ---- Web UI ----
WEB_PORT=8080

# ---- UniFi Protect (LOCAL access user, NOT a Ubiquiti SSO/cloud login) ----
UFP_ADDRESS=10.x.x.x
UFP_PORT=443
UFP_USERNAME=gawkr
UFP_PASSWORD=change-me
UFP_SSL_VERIFY=false
UFP_API_KEY=change-me

# ---- Vision model (your llama.cpp / Ollama OpenAI-compatible endpoint) ----
VISION_URL=http://10.x.x.x:8081/v1/chat/completions
VISION_MODEL=qwen2.5-vl
VISION_API_KEY=
VISION_TIMEOUT=60

# ---- Whisper transcription (optional; blank = off) ----
# Point at a whisper.cpp / faster-whisper server; scope to mic'd cameras.
WHISPER_URL=
WHISPER_TIMEOUT=120
TRANSCRIBE_CAMERAS=

# ---- Gotify alerts (blank URL+TOKEN = off) ----
GOTIFY_URL=
GOTIFY_TOKEN=
WEB_BASE_URL=http://<host>:8080
ALERT_ON_WEAPON=true
ALERT_THREAT_LEVEL=medium
ALERT_KEYWORDS=
ALERT_CAMERAS=
ALERT_COOLDOWN=120

# ---- Behaviour ----
IDENTIFY_VEHICLES=true
SMART_TYPES=person,vehicle,animal,licensePlate,package,face
EMBED_MODEL=BAAI/bge-small-en-v1.5
